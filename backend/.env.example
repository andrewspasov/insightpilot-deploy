
# Django / deployment
SECRET_KEY=replace_me_for_production
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,[::1],host.docker.internal
FRONTEND_BASE_URL=http://localhost:5173
WAGTAILADMIN_BASE_URL=http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080
CORS_ALLOW_ALL_ORIGINS=true
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080
USE_X_FORWARDED_HOST=false
SECURE_SSL_REDIRECT=false
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=false
SECURE_HSTS_PRELOAD=false

# YouTube Data API key for NTR (required)
YOUTUBE_API_KEY=your_real_youtube_api_key_here

# USDA FoodData Central API key for Nutrition (optional but recommended)
USDA_FOODDATA_CENTRAL_API_KEY=

# InsightPilot AI private test config.
# Provider can be openai or gemini.
INSIGHT_AI_PROVIDER=openai
INSIGHT_AI_OPENAI_API_KEY=
INSIGHT_AI_OPENAI_MODEL=gpt-4.1-nano
# Keep real provider keys only in backend/.env or Render env vars, never in frontend code.
INSIGHT_AI_GEMINI_API_KEY=
INSIGHT_AI_MODEL=gemini-2.5-flash-lite
INSIGHT_AI_ALLOWED_EMAILS=your-login-email@example.com
INSIGHT_AI_MONTHLY_MESSAGE_LIMIT=100
INSIGHT_AI_MONTHLY_TOKEN_LIMIT=100000
INSIGHT_AI_MAX_OUTPUT_TOKENS=700
INSIGHT_AI_TIMEOUT_SECONDS=30

# Database engine selector: sqlite (default) or postgres
DB_ENGINE=sqlite

# Optional: override SQLite DB path
# SQLITE_PATH=/absolute/path/to/db.sqlite3

# PostgreSQL connection (used when DB_ENGINE=postgres)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=insightpilot
POSTGRES_USER=insightpilot
POSTGRES_PASSWORD=insightpilot_dev_pw

# Stripe (test mode)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_GRACE_DAYS=7
